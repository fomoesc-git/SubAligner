{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SubAligner",
  "version": "1.0.2",
  "identifier": "com.subaligner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SubAligner - 配音文案字幕生成器",
        "width": 960,
        "height": 800,
        "minWidth": 800,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/subaligner-engine"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
